@page
@using System.Security.Claims;
@using Microsoft.Extensions.Options
@using PMS.UI.Options
@inject IOptions<AppSettings> appSettings

@model ChangePasswordModel
@{
	ViewData["Title"] = "Change User Password";
	var apiEndpoint = appSettings.Value.ApiEndpoint;
	var pageSize = appSettings.Value.DefaultPageSize;
	var email = User.FindFirst(ClaimTypes.Email)?.Value;
}

@section HeadBlock {
	<link href="~/lib/select2/css/select2.min.css" rel="stylesheet" />
}

<div class="page-header">
	<div class="page-title">
		<h4>@ViewData["Title"]</h4>
	</div>
</div>

<input name="__RequestVerificationToken" type="hidden" value="@HttpContext.Session.GetString("API_Token")">

<input type="hidden" id="redirectToListing" value="@Url.Page("/Authentication/Logout")" />

<div class="row">
	<div class="col-md-4">
		<form method="post" id="frmChangePassword">
			<div asp-validation-summary="ModelOnly" class="text-danger"></div>
			<div class="form-group">
				<label asp-for="ChangePassword.Email" class="control-label"></label>
				<input asp-for="ChangePassword.Email" class="form-control user-email" value="@email" disabled />
				<span asp-validation-for="ChangePassword.Email" class="text-danger"></span>
			</div>

			<div class="form-group">
				<label asp-for="ChangePassword.Password" class="control-label"></label>
				<input asp-for="ChangePassword.Password" type="password" class="form-control user-pws" />
				<span asp-validation-for="ChangePassword.Password" class="text-danger"></span>
			</div>

			<div class="form-group">
				<label asp-for="ChangePassword.NewPassword" class="control-label"></label>
				<input asp-for="ChangePassword.NewPassword" type="password" class="form-control user-newPws" />
				<span asp-validation-for="ChangePassword.NewPassword" class="text-danger"></span>
			</div>

			<div class="form-group">
				<label asp-for="ChangePassword.ConfirmNewPassword" class="control-label"></label>
				<input asp-for="ChangePassword.ConfirmNewPassword" type="password" class="form-control user-cnewPws" />
				<span asp-validation-for="ChangePassword.ConfirmNewPassword" class="text-danger"></span>
			</div>

			<div class="col-lg-12 d-grid gap-2 d-md-flex justify-content-md-end">
				<input type="submit" value="Submit" asp-page-handler="Submit" class="btn btn-primary submit-btn me-2" />
				<a href="javascript:void(0);" class="btn btn-secondary">Cancel</a>
			</div>

		</form>
	</div>
</div>

@section ScriptsBlock {
	<partial name="_ValidationScriptsPartial" />
	<script src="~/js/user.js" asp-append-version="true"></script>

	<script type="text/javascript">
		$('a[href="/Users/ChangePassword"]').addClass('active');

		debugger
		$(document).ready(function () {
		});
		$(function () {
		});

		// save
		var apiEndpoint = '@apiEndpoint';


		// function goBack() {
		// 	$("#goIndex")[0].click();
		// }

	</script>

}

