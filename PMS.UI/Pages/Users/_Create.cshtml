@model Models.ViewModels.User.CreateUserViewModel

<link href="~/lib/datatables.net-bs5/datatables.bootstrap5.min.css" rel="stylesheet" />
<link href="~/lib/select2/css/select2.min.css" rel="stylesheet" />
<link href="~/lib/select2-bootstrap-5-theme/select2-bootstrap-5-theme.min.css" rel="stylesheet">

<div class="modal fade" id="add-record" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="addRecordLabel" aria-hidden="true">
	<div class="modal-dialog">
		<div class="modal-content">

			<div class="modal-header">
				<h1 class="modal-title fs-5" id="staticBackdropLabel">Add New User</h1>
				<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
			</div>

			<input type="hidden" id="redirectToListing" value="@Url.Page("Index")" />

			<div class="modal-body">

				<form class="needs-validation" id="frmCreate" enctype="multipart/form-data">
					<div asp-validation-summary="ModelOnly" class="mb-3 text-danger"></div>
					<input name="IsValid" type="hidden" value="@ViewData.ModelState.IsValid.ToString()" />

					<input type="hidden" asp-for="EmployeeId" class="emp_id" id="emp-id" />

					<div class="col-lg-12 col-12">
						<div class="form-group">
							<label asp-for="Email" class="control-label"></label>
							<input asp-for="Email" class="form-control user-email" placeholder="name@example.com" />
							<span asp-validation-for="Email" class="text-danger"></span>
						</div>
					</div>

@* 					<div class="form-group">
						<label asp-for="EmployeeId" class="control-label"></label>
						<select asp-for="EmployeeId" required class="form-control select2 ddl-Employees col-lg-4 col-sm-6 col-12">
							<option value="0">Choose</option>
							</select>
						<span asp-validation-for="EmployeeId" class="text-danger"></span>
					</div> *@

					<div class="col-lg-12 col-12">
						<div class="form-group">
							<div>
								<label asp-for="EmployeeId" class="control-label">Employee</label>
								<select asp-for="EmployeeId" class="form-control ddl-Employees" id="employeeId">
									<option value="0">Choose</option>
								</select>
								<span asp-validation-for="EmployeeId" class="text-danger"></span>
							</div>
						</div>
					</div>

					<div class="col-lg-12 col-12">
						<div class="form-group">
							<div>
								<label asp-for="RoleId" class="control-label">User Role</label>
								<select asp-for="RoleId" class="form-control user-roles" id="userRole">
									<option value="0">Choose</option>
								</select>
								<span asp-validation-for="RoleId" class="text-danger"></span>
							</div>
						</div>
					</div>

					<div class="col-lg-12 col-12">
						<div class="form-group">
							<label asp-for="FirstName" class="control-label"></label>
							<input asp-for="FirstName" class="form-control user-fname" />
							<span asp-validation-for="FirstName" class="text-danger"></span>
						</div>
					</div>

					<div class="col-lg-12 col-12">
						<div class="form-group">
							<label asp-for="LastName" class="control-label"></label>
							<input asp-for="LastName" class="form-control user-lname" />
							<span asp-validation-for="LastName" class="text-danger"></span>
						</div>
					</div>

					<div class="col-lg-12 col-12">
						<div class="form-group">
							<label asp-for="Password" class="control-label"></label>
							<input asp-for="Password" type="password" class="form-control user-pws" />
							<span asp-validation-for="Password" class="text-danger"></span>
						</div>
					</div>

					<div class="col-lg-12 col-12">
						<div class="form-group">
							<label asp-for="ConfirmPassword" class="control-label"></label>
							<input asp-for="ConfirmPassword" type="password" class="form-control user-conPws" />
							<span asp-validation-for="ConfirmPassword" class="text-danger"></span>
						</div>
					</div>

					<div class="col-lg-12 d-grid gap-2 d-md-flex justify-content-md-end">
						<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
						<button type="submit" class="btn btn-primary submit-btn create-user" data-save="modal">Create</button>
					</div>


				</form>
			</div>

		</div>
	</div>
</div>

<script type="text/javascript">

	$(document).ready(function () {
		loadEmployees();
		loadUserRoles();
	});

</script>


