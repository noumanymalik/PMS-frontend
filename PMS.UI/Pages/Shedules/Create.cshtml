@page
@addTagHelper*,Microsoft.AspNetCore.Mvc.TagHelpers

@using Microsoft.Extensions.Options
@using PMS.UI.Options
@inject IOptions<AppSettings> appSettings

@model PMS.UI.Pages.Shedules.CreateModel
@{
	var apiEndpoint = appSettings.Value.ApiEndpoint;
	var pageSize = appSettings.Value.DefaultPageSize;
}

@section HeadBlock {
    <link href="~/lib/datatables.net-bs5/datatables.bootstrap5.min.css" rel="stylesheet" />
    <link href="~/lib/select2/css/select2.min.css" rel="stylesheet" />
    <link href="~/lib/select2-bootstrap-5-theme/select2-bootstrap-5-theme.min.css" rel="stylesheet">
    <link href="~/lib/bootstrap-daterangepicker/daterangepicker.min.css" rel="stylesheet">
}

<div class="row">
    <div class="col-sm-12">
        <div class="card">
            <div class="card-body">

                <div class="table-title p-2 me-1 mb-1">
                    <div class="col-12">
                        <div class="row">
                            <div class="col-6 col-xs-8">
                                <h4>Manage Rota</h4>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="table-filter">
                    <div class="mb-1">
                        <nav class="navbar navbar-light filter_inputs" style="background-color: transparent;">

                            <form method="post" enctype="multipart/form-data" class="col-12">

                                <div class="row align-items-center">
                                    <div class="row col-sm-10">

                                        <div class="filter-group col-sm-4 col-xs-6">
                                            <label>Select Month</label>
                                            <select id="ddlMonths" class="form-control select2 months">
                                            </select>
                                        </div>

                                        <div class="filter-group col-sm-4 col-xs-6">
                                            <label>Select Week</label>
                                            <select id="ddlWeeks" class="form-control select2 weeks">
                                            </select>
                                        </div>

                                    </div>

                                    <div class="col-sm-2 mt-auto pt-1">
                                        <form method="post" enctype="multipart/form-data">
                                            <input type="file" name="postedFile" class="form-control" />

                                            <button type="submit" asp-page-handler="Upload" class="btn btn-primary">
                                                Upload
                                            </button>
                                        </form>
                                    </div>

                                    <div class="col-sm-2 mt-auto pt-1">

                                        <button type="submit" id="upload-btn" class="btn btn-primary">
                                            Show
                                        </button>

                                    </div>


                                </div>

                            </form>
                        </nav>
                    </div>
                </div>

                <div class="modal fade" id="importModal" tabindex="-1">
                    <div class="modal-dialog">
                        <div class="modal-content">

                            <div class="modal-header">
                                <h5 class="modal-title">Import File</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>

                            <div class="modal-body">
                                <input type="file" class="form-control" />
                            </div>

                            <div class="modal-footer">
                                <button class="btn btn-success" id="fileInput">Upload</button>
                                <button class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                            </div>

                        </div>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table table-striped table-bordered table-hover" id="tblRota">

                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Employee ID</th>
                                <th>Employee Name</th>
                                <th>Monday</th>
                                <th>Tuesday</th>
                                <th>Wednesday</th>
                                <th>Thursday</th>
                                <th>Friday</th>
                                <th>Saturday</th>
                                <th>Sunday</th>
                            </tr>
                        </thead>
                        <tbody class="table-body">
                        </tbody>
                    </table>

                </div>

                <div class="clearfix"></div>


            </div>
        </div>
    </div>
</div>


