@page
@using Microsoft.Extensions.Options
@using PMS.UI.Options
@inject IOptions<AppSettings> appSettings

@model PMS.UI.Pages.Leaves.PendingModel
@{
    var apiEndpoint = appSettings.Value.ApiEndpoint;
    var pageSize = appSettings.Value.DefaultPageSize;
}

@using System.Security.Claims;
@{
    var employeeId = User.FindFirst(ClaimTypes.Actor)?.Value;
}

@section HeadBlock {
    <link href="~/lib/datatables.net-bs5/datatables.bootstrap5.min.css" rel="stylesheet" />
    <link href="~/lib/select2/css/select2.min.css" rel="stylesheet" />
}

<div class="page-header">
    <div class="page-title">
    </div>
</div>

<input name="__RequestVerificationToken" type="hidden" value="@HttpContext.Session.GetString("API_Token")">

<div class="row">
    <div class="col-sm-12">
        <div class="card">
            <div class="card-body">

                <div class="table-title p-2 me-1 mb-1">
                    <div class="row">
                        <div class="col-sm-4">
                            <h4>Pending Leave for Approval</h4>
                        </div>
                    </div>
                </div>

                <div id="result" class="mt-3"></div>

                <div class="table-responsive">
                    <table class="table table-striped table-hover table-bordered" id="tblLeaves">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Date</th>
                                <th>Identifcation No.</th>
                                <th>Name</th>
                                <th>From Date</th>
                                <th>To Date</th>
                                <th>No Of Days</th>
                                <th>Leave Type</th>
                                <th>Reason</th>
                                <th>Action(s)</th>
                            </tr>
                        </thead>
                        <tbody class="table-body">
                        </tbody>
                    </table>

                </div>

                <div class="clearfix"></div>


            </div>
        </div>
    </div>
</div>

@section ScriptsBlock {
    <partial name="_ValidationScriptsPartial" />
    <script type="text/javascript" src="~/lib/datatables.net/jquery.dataTables.min.js"></script>
    <script type="text/javascript" src="~/lib/datatables.net-bs5/dataTables.bootstrap5.min.js"></script>
    <script type="text/javascript" src="~/lib/select2/js/select2.min.js"></script>
    <script type="text/javascript" src="~/lib/moment.js/moment.min.js"></script>

    <script type="text/javascript">
        $('a[href="/Leaves/Pending"]').addClass('active');

        var apiEndpoint = '@apiEndpoint';
        var employeeId = '@employeeId';

        $(document).ready(function () {
             loadData();
        });

        $(document).on('click', '.approve-btn', function (event) {
            event.preventDefault();

            const recordId = $(this).data('id');

            Swal.fire({
                title: "Approve this request?",
                icon: "warning",
                showCancelButton: true,
                confirmButtonText: "Yes, approve"
            }).then((result) => {

                if (!result.isConfirmed) return;

                $.blockUI({ baseZ: 1055, message: '<h5>Processing...</h5>' });

                $.ajax({
                    type: 'PUT',
                    url: apiEndpoint + 'Leaves/' + recordId,
                    contentType: 'application/json',
                    headers: {
                     'Authorization': 'Bearer ' + $('input:hidden[name="__RequestVerificationToken"]').val(),
                    },
                    data: JSON.stringify({
                        id: recordId,
                        approvalTypeId: 2 
                    }),

                    success: function (data) {
                        if (data.succeeded) {
                            toastr.success(data.messages[0]);
                            $('#tblLeaves').DataTable().ajax.reload(null, false);
                        } else {
                            toastr.error(data.messages[0]);
                        }
                    },

                    error: function () {
                        toastr.error('Something went wrong');
                    },

                    complete: function () {
                        $.unblockUI();
                    }
                });
            });
        });

        $(document).on('click', '.reject-btn', function (event) {
            event.preventDefault();

            const recordId = $(this).data('id');

            Swal.fire({
                title: "Reject this request?",
                icon: "warning",
                showCancelButton: true,
                confirmButtonText: "Yes, reject"
            }).then((result) => {

                if (!result.isConfirmed) return;

                $.blockUI({ baseZ: 1055, message: '<h5>Processing...</h5>' });

                $.ajax({
                    type: 'PUT',
                    url: apiEndpoint + 'Leaves/' + recordId,
                    contentType: 'application/json',
                    headers: {
                      'Authorization': 'Bearer ' + $('input:hidden[name="__RequestVerificationToken"]').val(),
                     },
                    data: JSON.stringify({
                        id: recordId,
                        approvalTypeId: 3 
                    }),

                    success: function (data) {
                        if (data.succeeded) {
                            toastr.success(data.messages[0]);
                            $('#tblLeaves').DataTable().ajax.reload(null, false);
                        } else {
                            toastr.error(data.messages[0]);
                        }
                    },

                    complete: function () {
                        $.unblockUI();
                    }
                });
            });
        });

        var $dg = {};
        var oTable;

         function loadData() {

            // destroy if already exists
            if ($.fn.DataTable.isDataTable('#tblLeaves')) {
                $('#tblLeaves').DataTable().destroy();
            }

             oTable = $('#tblLeaves').DataTable(getDtOptions());
        }

          function getDtOptions() {
            return {
                destroy: true,
                processing: true,
                serverSide: true,
                ordering: false,
                searching: false,
                autoWidth: false,
                lengthChange: false,
                pageLength: @pageSize,

                ajax: {
                     url: apiEndpoint + 'Leaves/GetEmployeeLeavesBySupId',
                     contentType: 'application/json',
                     headers: {
                       'Authorization': 'Bearer ' + $('input:hidden[name="__RequestVerificationToken"]').val(),
                      },
                    data: function (data, settings) {
                        var api = new $.fn.dataTable.Api(settings);
                        var pageIndex = api.page.info().page + 1;

                        return {
                            PageIndex: pageIndex,
                            PageSize: @pageSize,
                            supervisorId: employeeId,
                            ApprovalTypeId: 1
                        };
                    },
                    dataSrc: function (json) {
                        var totalRows = json.rowCount;
                        json.recordsTotal = totalRows;
                        json.recordsFiltered = totalRows;
                        return json.data;
                    }
                },

                createdRow: function (row, data) {
                    $(row).attr('data-id', data.id);
                },

                columns: [
                    {
                        data: '#',
                        title: '#',
                        width: "3%",
                        render: function (data, type, row, meta) {
                            return meta.row + meta.settings._iDisplayStart + 1;
                        }
                    },
                    {
                        data: 'createDate',
                        width: '5%',
                        render: function (data) {
                            return moment(data).format('MM/DD/YYYY');
                        }
                    },
                    { data: 'code', width: '5%' },
                    { data: 'employeeName', width: '10%' },
                    {
                        data: 'fromDate',
                        width: '5%',
                        render: function (data) {
                            return moment(data).format('MM/DD/YYYY');
                        }
                    },
                    {
                        data: 'toDate',
                        width: '5%',
                        render: function (data) {
                            return moment(data).format('MM/DD/YYYY');
                        }
                    },
                    { data: 'noOfDays', width: '5%' },
                    { data: 'leaveType', width: '5%' },
                    { data: 'reason', width: '25%' },
                    {
                         data: 'id',
                         title: 'Action(s)',
                         width: '10%',
                         render: function (data, type, row, meta) {

                        return '<a data-id="' + data + '" href="#" class="btn btn-sm btn-outline-success approve-btn me-2">' + '<i class="fas fa-check me-1"></i>Approve</a>' +
                               '<a data-id="' + data + '" href="#" class="btn btn-sm btn-outline-danger reject-btn">' + '<i class="fas fa-times me-1"></i>Reject</a>';
                         }
                    }
                ],

                language: {
                    searchPlaceholder: "Search...",
                    search: "",
                    lengthMenu: "_MENU_ &nbsp;items/page"
                }
            };
        }

    </script>
}
