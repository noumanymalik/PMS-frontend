@page
@using Microsoft.Extensions.Options
@using PMS.UI.Options
@inject IOptions<AppSettings> appSettings

@model PMS.UI.Pages.Loan.LoanStatusModel
@{
    var apiEndpoint = appSettings.Value.ApiEndpoint;
    var pageSize = appSettings.Value.DefaultPageSize;
}
@using System.Security.Claims;
@{
    var employeeId = User.FindFirst(ClaimTypes.Actor)?.Value;
}

@section HeadBlock {
    <link href="~/lib/datatables.net-bs5/datatables.bootstrap5.min.css" rel="stylesheet" />
    <link href="~/lib/select2/css/select2.min.css" rel="stylesheet" />
}

<div class="page-header">
    <div class="page-title">
    </div>
</div>

<input name="__RequestVerificationToken" type="hidden" value="@HttpContext.Session.GetString("API_Token")">

<div class="row">
    <div class="col-sm-12">
        <div class="card">
            <div class="card-body">

                <div class="table-title p-2 me-1 mb-1">
                    <div class="row">
                        <div class="col-sm-4">
                            <h4>Loan Applications Status</h4>
                        </div>
                    </div>
                </div>

                <div id="result" class="mt-3"></div>

                <div class="table-responsive">
                    <table class="table table-striped table-hover table-bordered" id="tblLoanStatus">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Date</th>
                                <th>Identifcation No.</th>
                                <th>Amount</th>
                                <th>Installments</th>
                                <th>Status</th>
                                <th>Reason</th>
                            </tr>
                        </thead>
                        <tbody class="table-body">
                        </tbody>
                    </table>

                </div>

                <div class="clearfix"></div>


            </div>
        </div>
    </div>
</div>

@section ScriptsBlock {
    <partial name="_ValidationScriptsPartial" />
    <script type="text/javascript" src="~/lib/datatables.net/jquery.dataTables.min.js"></script>
    <script type="text/javascript" src="~/lib/datatables.net-bs5/dataTables.bootstrap5.min.js"></script>
    <script type="text/javascript" src="~/lib/select2/js/select2.min.js"></script>
    <script type="text/javascript" src="~/lib/moment.js/moment.min.js"></script>

    <script type="text/javascript">
        $('a[href="/Loan/LoanStatus"]').addClass('active');

        var apiEndpoint = '@apiEndpoint';
        var employeeId = '@employeeId';

        $(document).ready(function () {
             loadData();
        });

        var $dg = {};
        var oTable;

         function loadData() {

            // destroy if already exists
            if ($.fn.DataTable.isDataTable('#tblLoanStatus')) {
                $('#tblLoanStatus').DataTable().destroy();
            }

             oTable = $('#tblLoanStatus').DataTable(getDtOptions());
        }

          function getDtOptions() {
            return {
                destroy: true,
                processing: true,
                serverSide: true,
                ordering: false,
                searching: false,
                autoWidth: false,
                lengthChange: false,
                pageLength: @pageSize,

                ajax: {
                     url: apiEndpoint + 'Loan/LoanRequestListbyEmployeeId?EmployeeId=' + employeeId,
                     contentType: 'application/json',
                     headers: {
                       'Authorization': 'Bearer ' + $('input:hidden[name="__RequestVerificationToken"]').val(),
                      },
                    data: function (data, settings) {
                        var api = new $.fn.dataTable.Api(settings);
                        var pageIndex = api.page.info().page + 1;

                        return {
                            PageIndex: pageIndex,
                            PageSize: @pageSize,
                            EmployeeId: employeeId,
                        };
                    },
                    dataSrc: function (json) {
                        var totalRows = json.rowCount;
                        json.recordsTotal = totalRows;
                        json.recordsFiltered = totalRows;
                        return json.data;
                    }
                },

                createdRow: function (row, data) {
                    $(row).attr('data-id', data.id);
                },

                columns: [
                    {
                        data: '#',
                        title: '#',
                        width: "3%",
                        render: function (data, type, row, meta) {
                            return meta.row + meta.settings._iDisplayStart + 1;
                        }
                    },
                    {
                        data: 'createDate',
                        width: '5%',
                        render: function (data) {
                            return moment(data).format('MM/DD/YYYY');
                        }
                    },
                    { data: 'code', width: '5%' },
                    { data: 'amount', width: '5%' },
                    { data: 'installment', width: '5%' },
                    { data: 'status', width: '5%' },
                    { data: 'reason', width: '25%' }
                ],

                language: {
                    searchPlaceholder: "Search...",
                    search: "",
                    lengthMenu: "_MENU_ &nbsp;items/page"
                }
            };
        }

    </script>
}

