@page
@using Microsoft.Extensions.Options
@using PMS.UI.Options
@inject IOptions<AppSettings> appSettings
@model PMS.UI.Pages.Loan.CreateModel
@{
    ViewData["Title"] = "Loan Request Form";
    var apiEndpoint = appSettings.Value.ApiEndpoint;
}

@using System.Security.Claims;
@{
	var employeeId = User.FindFirst(ClaimTypes.Actor)?.Value;
}

@section HeadBlock {
	<link href="~/lib/select2/css/select2.min.css" rel="stylesheet" />
}

<div class="page-header">
	<div class="page-title">
		<h4>@ViewData["Title"]</h4>
		<h6>Apply For Loan</h6>
	</div>
</div>

<style>
    #frmLoanDetail .mb-2 {
        margin-bottom: .5rem !important;
    }

    #frmLoanDetail label {
        margin-bottom: 2px;
        font-weight: 500;
    }

    #frmLoanDetail .form-control {
        padding-top: .35rem;
        padding-bottom: .35rem;
    }

    #frmLoanDetail textarea {
        resize: vertical;
    }
</style>

<input name="__RequestVerificationToken" type="hidden" value="@HttpContext.Session.GetString("API_Token")">

<input type="hidden" id="redirectToListing" value="@Url.Page("LoanStatus")" />

<div class="container-fluid">
    <div class="row">
        <div class="col-md-6">
            <form method="post" id="frmLoanDetail">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <input type="hidden" asp-for="CreateLoan.EmployeeId" value="employeeId" />

                <div class="mb-2">
                    <label asp-for="CreateLoan.Date" class="control-label"></label>
                    <input asp-for="CreateLoan.Date"
                           type="date"
                           class="form-control"
                           id="loan-date"
                           readonly />
                    <span asp-validation-for="CreateLoan.Date" class="text-danger"></span>
                </div>

                <div class="mb-2">
                    <label class="control-label">Joining Date</label>
                    <input class="form-control join-date" readonly />

                    <small id="joiningDateWarning"
                           class="text-danger"
                           style="display:none;">
                        Joining date is less than three months.
                    </small>
                </div>

                <div class="mb-2">
                    <label class="control-label">Contact No</label>
                    <input class="form-control cont-no" readonly />
                </div>

                <div class="mb-2">
                    <label class="control-label">Address</label>
                    <textarea class="form-control address" rows="2" readonly></textarea>
                </div>

                <div class="mb-2">
                    <label class="control-label">Designation</label>
                    <input class="form-control designation" readonly />
                </div>

                <div class="mb-2 d-flex justify-content-between align-items-center">

                    <div class="d-flex align-items-center gap-3">
                        <label class="mb-0">
                            Any loan disbursals within the preceding 90 days?
                        </label>

                        <div class="form-check form-check-inline mb-0">
                            <input class="form-check-input"
                                   type="radio"
                                   name="Loan90DaysDisplay"
                                   value="1"
                                   id="rblYes"
                                   disabled />
                            <label class="form-check-label" for="rblYes">
                                Yes
                            </label>
                        </div>

                        <div class="form-check form-check-inline mb-0">
                            <input class="form-check-input"
                                   type="radio"
                                   name="Loan90DaysDisplay"
                                   value="2"
                                   id="rblNo"
                                   disabled />
                            <label class="form-check-label" for="rblNo">
                                No
                            </label>
                        </div>
                    </div>

                    <div class="d-flex align-items-center gap-2">
                        <label for="LastLoanDate" class="mb-0">
                            Last Loan Apply Date
                        </label>

                        <input type="text"
                               id="LastLoanDate"
                               name="LastLoanDate"
                               class="form-control last-Loan"
                               style="width:180px;"
                               readonly />
                    </div>
                </div>
                <small id="loan90DaysWarning"
                       class="text-danger"
                       style="display:none;">
                    Already taken a loan within the last 90 days.
                </small>

                <div class="mb-2">
                    <label asp-for="CreateLoan.Amount" class="control-label"></label>
                    <input asp-for="CreateLoan.Amount"
                           type="number"
                           class="form-control loan-amt"
                           oninput="this.value=this.value.replace(/[^0-9]/g,'')" 
                           id="loanamt" />
                    <span asp-validation-for="CreateLoan.Amount" class="text-danger"></span>
                </div>

                <div class="mb-2">
                    <label asp-for="CreateLoan.InstallmentId" class="control-label"></label>
                    <select asp-for="CreateLoan.InstallmentId" id="inst-Type" class="form-control">
                        <option value="">-- Select Installment --</option>
                        <option value="1">1 Month</option>
                        <option value="2">2 Months</option>
                        <option value="3">3 Months</option>
                        <option value="4">4 Months</option>
                    </select>
                    <span asp-validation-for="CreateLoan.InstallmentId" class="text-danger"></span>
                </div>

                <div class="mb-2">
                    <label asp-for="CreateLoan.Reason" class="control-label"></label>
                    <textarea asp-for="CreateLoan.Reason"
                              class="form-control"
                              id="loan-reason"
                              rows="2"></textarea>
                    <span asp-validation-for="CreateLoan.Reason" class="text-danger"></span>
                </div>

                <div class="mt-3">
                    <input type="submit"
                           value="Send For Approval"
                           class="btn btn-primary" />
                </div>
            </form>
        </div>
    </div>
</div>
@section ScriptsBlock {
	<partial name="_ValidationScriptsPartial" />
	<script type="text/javascript" src="~/lib/select2/js/select2.min.js"></script>
	<script type="text/javascript" src="~/lib/datatables.net/jquery.dataTables.min.js"></script>
	<script type="text/javascript" src="~/lib/moment.js/moment.min.js"></script>
	<script type="text/javascript" src="~/lib/bootstrap-datetimepicker/bootstrap-datetimepicker.min.js"></script>
	<script type="text/javascript" src="~/lib/jquery-mask/jquery.mask.min.js"></script>

	<script type="text/javascript">
		$('a[href="/Loan/Create"]').addClass('active');

		var apiEndpoint = '@apiEndpoint';
		var employeeId = '@employeeId';

		$(document).ready(function () {
			let today = new Date().toISOString().split('T')[0];
			$('#loan-date').val(today);
            loadForm();
            // checkJoiningDate();
		});

        function formatDate(dateString) {
            if (!dateString) return '';

            const date = new Date(dateString);

            return (date.getMonth() + 1).toString().padStart(2, '0') + ' / ' +
                   date.getDate().toString().padStart(2, '0') + ' / ' +
                   date.getFullYear();
        }

        function loadForm() {
            $.ajax({
                type: 'GET',
                url: apiEndpoint + 'Loan/GetEmployeeForLoanRequest?employeeId=' + employeeId,
                contentType: 'application/json; charset=utf-8',
                dataType: 'json',
                headers: {
                    'Authorization': 'Bearer ' + $('input:hidden[name="__RequestVerificationToken"]').val(),
                },
                success: function (response) {

                    // $('#loan-date').val(new Date(response.data.createDate).toLocaleDateString('en-US'));
                    $('.join-date').val(formatDate(response.data.joiningDate) || '');
                    $('.cont-no').val(response.data.contactNo || '');
                    $('.address').val(response.data.address || '');
                    $('.designation').val(response.data.designation || '');
                    $('.last-Loan').val(formatDate(response.data.lastLoanDate) || '');

                    checkJoiningDate();

                    if (response.data.ninetyDaysLoan == 1) {
                        $('#rblYes').prop('checked', true);
                        ShowLoan90Days();
                    }
                    else if (response.data.ninetyDaysLoan == 2) {
                        $('#rblNo').prop('checked', true);
                    }
                }
            });
        }

        function checkJoiningDate() {

        var dateText = $('.join-date').val()?.trim();

            if (dateText) {

                var joiningDate = new Date(dateText);
                var today = new Date();

                var months =
                    (today.getFullYear() - joiningDate.getFullYear()) * 12 +
                    (today.getMonth() - joiningDate.getMonth());

                if (months < 3) {
                    $('#joiningDateWarning').show();
                }
            }
        }

        function ShowLoan90Days() {

           $('#loan90DaysWarning').show();
        }

        $('#frmLoanDetail').on('submit', function (e) {
			e.preventDefault();

            if (!$('#frmLoanDetail').valid()) {
				return;
			}
			debugger
			var formData = {
                createDate: $('#loan-date').val(),
				employeeId: employeeId,
                installmentId: $("#inst-Type option:selected").val(),
                amount: $('#loanamt').val(),
                reason: $('#loan-reason').val(),
			};

			$.blockUI({ baseZ: 1001, message: '<h1>Processing...</h1>' });

			$.ajax({
				type: 'POST',
                url: apiEndpoint + 'Loan',
				contentType: 'application/json; charset=utf-8',
				dataType: 'json',
				data: JSON.stringify(formData),
				headers: {
					'Authorization': 'Bearer ' + $('input:hidden[name="__RequestVerificationToken"]').val(),
				},
				success: function (data) {
					$.unblockUI();
					if (data.succeeded) {
						toastr.success(data.messages[0]);
						window.setInterval(goBack, 1000);
					}
					else {
						toastr.error(data.message);
					}
				},
				error: function (jqXHR, textStatus, errorThrown) {
					$.unblockUI();
					var errors = JSON.parse(jqXHR.responseText).errors;
					$.each(jqXHR.responseJSON.errors, function (field, message) {
						toastr.error(message);
					});
				}
			}).done(function (result) {
				console.log(result);
			});
		});

		function goBack() {
			window.location.href = $('#redirectToListing').val();
		}

	</script>

}
