@model Models.ViewModels.User.CreateRoleViewModel
<div class="modal fade" id="add-userRole" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="addRecordLabel" aria-hidden="true">
	<div class="modal-dialog">
		<div class="modal-content">

			<div class="modal-header">
				<h1 class="modal-title fs-5" id="staticBackdropLabel">Add New User Role</h1>
				<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
			</div>

			<input type="hidden" id="redirectToListing" value="@Url.Page("Index")" />

			<div class="modal-body">

				<form class="needs-validation" id="frmCreate" enctype="multipart/form-data">
					<div asp-validation-summary="ModelOnly" class="mb-3 text-danger"></div>
					<input name="IsValid" type="hidden" value="@ViewData.ModelState.IsValid.ToString()" />

					<div class="col-lg-12 col-12">
						<div class="form-group">
							<label asp-for="Name" class="control-label"></label>
							<input asp-for="Name" required class="form-control role-name" />
							<span asp-validation-for="Name" class="text-danger"></span>
						</div>
					</div>

					<div class="col-lg-12 d-grid gap-2 d-md-flex justify-content-md-end">
						<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
						<button type="submit" class="btn btn-primary submit-btn create-userRole" data-save="modal">Create</button>
					</div>

				</form>
			</div>

		</div>
	</div>
</div>

<script type="text/javascript">

</script>
